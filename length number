import java.util.Scanner;

class Node{

    int data;
    Node next;
    Node prev;

    Node(int data){
        this.data = data;
        this.next = null;
        this.prev = null;
    }
}

class DoublyLinkedList{

    Node head;

    void insertAtEnd(int data){

        Node newNode = new Node(data);

        if(head == null){
            head = newNode;
            return;
        }

        Node temp = head;

        while(temp.next != null){
            temp = temp.next;
        }

        temp.next = newNode;
        newNode.prev = temp;
    }

    int findLength(){

        Node temp = head;

        int count = 0;

        while(temp != null){

            count++;

            temp = temp.next;
        }

        return count;
    }
}

public class Main{

    public static void main(String[] args){

        Scanner sc = new Scanner(System.in);

        DoublyLinkedList list = new DoublyLinkedList();

        System.out.print("How many nodes: ");
        int n = sc.nextInt();

        for(int i = 1; i <= n; i++){

            System.out.print("Enter data: ");
            int data = sc.nextInt();

            list.insertAtEnd(data);
        }

        int length = list.findLength();

        System.out.println("Length = " + length);
    }
}
