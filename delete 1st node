import java.util.Scanner;

class Node{

    int data;
    Node next;
    Node prev;

    Node(int data){
        this.data = data;
        this.next = null;
        this.prev = null;
    }
}

class DoublyLinkedList{

    Node head;

    void insertAtEnd(int data){

        Node newNode = new Node(data);

        if(head == null){
            head = newNode;
            return;
        }

        Node temp = head;

        while(temp.next != null){
            temp = temp.next;
        }

        temp.next = newNode;
        newNode.prev = temp;
    }

    void deleteFirst(){

        // empty list
        if(head == null){
            System.out.println("List is empty");
            return;
        }

        // only one node
        if(head.next == null){
            head = null;
            return;
        }

        // move head
        head = head.next;

        // remove backward link
        head.prev = null;
    }

    void display(){

        Node temp = head;

        while(temp != null){
            System.out.print(temp.data + " ");
            temp = temp.next;
        }
    }
}

public class Main{

    public static void main(String[] args){

        Scanner sc = new Scanner(System.in);

        DoublyLinkedList list = new DoublyLinkedList();

        
        int n = sc.nextInt();

        for(int i = 1; i <= n; i++){

            
            int data = sc.nextInt();

            list.insertAtEnd(data);
        }

        
        
        list.deleteFirst();

        
        list.display();
    }
}
