import java.util.Scanner;

class Node{
    int data;
    Node next;
    Node prev;

    Node(int data){
        this.data = data;
        this.next = null;
        this.prev = null;
    }
}

class DoublyLinkedList{

    Node head;

    void insertAtEnd(int data){

        Node newNode = new Node(data);

        // empty list
        if(head == null){
            head = newNode;
            return;
        }

        Node temp = head;

        // last node ku po
        while(temp.next != null){
            temp = temp.next;
        }

        // connection
        temp.next = newNode;
        newNode.prev = temp;
    }

    void display(){

        Node temp = head;

        while(temp != null){
            System.out.print(temp.data + " ");
            temp = temp.next;
        }
    }
}

public class Main{

    public static void main(String[] args){

        Scanner sc = new Scanner(System.in);

        DoublyLinkedList list = new DoublyLinkedList();

        
        int n = sc.nextInt();

        for(int i = 1; i <= n; i++){

           
            int data = sc.nextInt();

            list.insertAtEnd(data);
        }
        int x = sc.nextInt();
list.insertAtEnd(x);
        

        list.display();
    }
}
